# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BUSINESS_CONNECTION_ID=

# ─────────────────────────────────────────────
# LLMs
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Modelos OpenRouter para la Persona (Alba).
# IMPORTANTE: los modelos NSFW/uncensored aparecen y desaparecen rápido en OpenRouter.
# Verifica disponibilidad cada 3-6 meses con: node scripts/check-openrouter-models.js
#
# Modelo activo (verificado abril 2026):
#   x-ai/grok-3-beta                — mejor seguimiento de instrucciones, $3/$15 per 1M, 131k ctx
#
# Alternativas si Grok falla o sube de precio:
#   sao10k/l3.3-euryale-70b         — roleplay sin censura, $0.65/$0.75 per 1M (ignoraba instrucciones)
#   nousresearch/hermes-3-llama-3.1-70b — alternativa, $0.30 per 1M
#
# Fallbacks gratuitos:
#   cognitivecomputations/dolphin-mistral-24b-venice-edition:free — GRATIS, 33k ctx
#   nousresearch/hermes-3-llama-3.1-405b:free                     — GRATIS, 131k ctx
MODEL_PERSONA=x-ai/grok-3-beta
MODEL_PERSONA_FALLBACK=cognitivecomputations/dolphin-mistral-24b-venice-edition:free

# ─────────────────────────────────────────────
# Pagos
# ─────────────────────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
PAYPAL_ENABLED=false

# ─────────────────────────────────────────────
# WhatsApp (Twilio)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
OWNER_WHATSAPP_TO=
PARTNER_WHATSAPP_TO=

# ─────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://botuser:botpass@localhost:5433/ofmbot

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
WEBHOOK_BASE_URL=https://bot-dev.luxemodels.eu

# Test mode — when true, sendMessage does NOT hit Telegram API (no-op, logs SKIPPED).
# Used by scripts/auto-iterate.js + scripts/fake-client.js during automated testing.
TEST_MODE=false

# ─────────────────────────────────────────────
# GitHub (para MCP server-github)
# ─────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
